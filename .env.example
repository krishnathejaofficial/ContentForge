# ─── Content APIs ─────────────────────────────────────────────────────────────
# Free tier available at https://newsapi.org/
NEWS_API_KEY=your_newsapi_key_here

# Free tier at https://api-ninjas.com/
API_NINJAS_KEY=your_api_ninjas_key_here

# ─── Image APIs ───────────────────────────────────────────────────────────────
# Free at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_key_here

# Free at https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_key_here

# ─── LLM (Script Engine) ──────────────────────────────────────────────────────
# Free tier at https://aistudio.google.com/ (Gemini)
GEMINI_API_KEY=your_gemini_key_here

# OR NVIDIA NIM free tier at https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_key_here

# ─── App Config ───────────────────────────────────────────────────────────────
OUTPUT_DIR=output
ASSETS_DIR=assets
PORT=8000
